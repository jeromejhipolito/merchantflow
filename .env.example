# ============================================================================
# MerchantFlow — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
# docker-compose.yml provides PostgreSQL and Redis locally.

# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=debug

# Database (PostgreSQL)
DATABASE_URL=postgresql://merchantflow:merchantflow_dev@localhost:5432/merchantflow

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=change-me-in-production-use-a-32-char-minimum-secret
API_KEY_SALT=change-me-too-use-a-random-string

# Shopify (mocked in development)
SHOPIFY_API_KEY=mock-shopify-api-key
SHOPIFY_API_SECRET=mock-shopify-api-secret
SHOPIFY_APP_URL=http://localhost:3000

# Idempotency
IDEMPOTENCY_KEY_TTL_HOURS=24

# Outbox Poller
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=50

# Encryption (for storing Shopify access tokens)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
