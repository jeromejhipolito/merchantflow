generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto]
}

// Store is the tenant boundary (1:1 with a Shopify shop)
model Store {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  shopifyDomain      String  @unique @map("shopify_domain")
  shopifyAccessToken  String  @map("shopify_access_token")
  shopifyScopes       String  @map("shopify_scopes")
  shopifyWebhookSecret String? @map("shopify_webhook_secret")
  name     String
  email    String
  currency String  @default("USD") @db.VarChar(3)
  timezone String  @default("UTC")

  status   StoreStatus @default(ACTIVE)

  webhookEndpoints WebhookEndpoint[]
  products   Product[]
  orders     Order[]
  shipments  Shipment[]
  outboxEvents OutboxEvent[]
  idempotencyKeys IdempotencyKey[]

  @@index([status])
  @@index([shopifyDomain])
  @@map("stores")
}

enum StoreStatus {
  ACTIVE
  SUSPENDED
  UNINSTALLED
}

// Products synced from Shopify
model Product {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  storeId String @map("store_id") @db.Uuid
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Restrict)

  shopifyProductId String @map("shopify_product_id")

  title       String
  description String?  @db.Text
  vendor      String?
  productType String?  @map("product_type")
  status      ProductStatus @default(ACTIVE)

  sku              String?
  barcode          String?
  inventoryQuantity Int     @default(0) @map("inventory_quantity")
  weight           Decimal? @db.Decimal(10, 2)
  weightUnit       String?  @default("kg") @map("weight_unit") @db.VarChar(5)

  price        Decimal @db.Decimal(12, 2)
  compareAtPrice Decimal? @map("compare_at_price") @db.Decimal(12, 2)
  currencyCode String  @default("USD") @map("currency_code") @db.VarChar(3)

  hsCode       String? @map("hs_code") @db.VarChar(12)
  countryOfOrigin String? @map("country_of_origin") @db.VarChar(2)

  shopifySyncedAt DateTime? @map("shopify_synced_at")

  lineItems LineItem[]

  @@unique([storeId, shopifyProductId], name: "uq_store_shopify_product")
  @@index([storeId, status])
  @@index([storeId, sku])
  @@index([storeId, shopifySyncedAt])
  @@map("products")
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

// Orders synced from Shopify webhooks
model Order {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  storeId String @map("store_id") @db.Uuid
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Restrict)

  shopifyOrderId String @map("shopify_order_id")
  orderNumber    String @map("order_number")
  subtotalPrice  Decimal @map("subtotal_price") @db.Decimal(12, 2)
  totalTax       Decimal @default(0) @map("total_tax") @db.Decimal(12, 2)
  totalShipping  Decimal @default(0) @map("total_shipping") @db.Decimal(12, 2)
  totalDiscount  Decimal @default(0) @map("total_discount") @db.Decimal(12, 2)
  totalPrice     Decimal @map("total_price") @db.Decimal(12, 2)
  currencyCode   String  @default("USD") @map("currency_code") @db.VarChar(3)

  financialStatus   OrderFinancialStatus @default(PENDING) @map("financial_status")
  fulfillmentStatus OrderFulfillmentStatus @default(UNFULFILLED) @map("fulfillment_status")

  customerEmail     String? @map("customer_email")
  customerFirstName String? @map("customer_first_name")
  customerLastName  String? @map("customer_last_name")
  customerPhone     String? @map("customer_phone")

  shippingAddressLine1   String? @map("shipping_address_line1")
  shippingAddressLine2   String? @map("shipping_address_line2")
  shippingCity           String? @map("shipping_city")
  shippingProvince       String? @map("shipping_province")
  shippingPostalCode     String? @map("shipping_postal_code")
  shippingCountryCode    String? @map("shipping_country_code") @db.VarChar(2)
  shippingPhone          String? @map("shipping_phone")

  customsDeclarationValue Decimal? @map("customs_declaration_value") @db.Decimal(12, 2)

  shopifyCreatedAt DateTime? @map("shopify_created_at")
  shopifySyncedAt  DateTime? @map("shopify_synced_at")

  lineItems  LineItem[]
  shipments  Shipment[]

  @@unique([storeId, shopifyOrderId], name: "uq_store_shopify_order")
  @@index([storeId, fulfillmentStatus])
  @@index([storeId, financialStatus])
  @@index([storeId, createdAt])
  @@index([storeId, customerEmail])
  @@index([storeId, orderNumber])
  @@map("orders")
}

enum OrderFinancialStatus {
  PENDING
  AUTHORIZED
  PARTIALLY_PAID
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  VOIDED
}

enum OrderFulfillmentStatus {
  UNFULFILLED
  PARTIALLY_FULFILLED
  FULFILLED
  RESTOCKED
}

model LineItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orderId String @map("order_id") @db.Uuid
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Restrict)

  productId String? @map("product_id") @db.Uuid
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  shopifyLineItemId String @map("shopify_line_item_id")
  title       String
  variantTitle String? @map("variant_title")
  sku         String?
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal @map("total_price") @db.Decimal(12, 2)

  fulfilledQuantity Int @default(0) @map("fulfilled_quantity")
  hsCode          String? @map("hs_code") @db.VarChar(12)
  countryOfOrigin String? @map("country_of_origin") @db.VarChar(2)
  weight          Decimal? @db.Decimal(10, 2)
  weightUnit      String?  @default("kg") @map("weight_unit") @db.VarChar(5)

  @@unique([orderId, shopifyLineItemId], name: "uq_order_shopify_line_item")
  @@index([orderId])
  @@index([productId])
  @@map("line_items")
}

// One order can have multiple shipments (partial fulfillment)
model Shipment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  storeId String @map("store_id") @db.Uuid
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Restrict)

  orderId String @map("order_id") @db.Uuid
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Restrict)

  carrier        String?
  service        String?
  trackingNumber String? @map("tracking_number")
  trackingUrl    String? @map("tracking_url")

  labelUrl       String? @map("label_url")
  labelFormat    String? @map("label_format") @db.VarChar(10)
  labelGeneratedAt DateTime? @map("label_generated_at")

  status ShipmentStatus @default(PENDING)
  weightGrams  Int?     @map("weight_grams")
  lengthCm     Decimal? @map("length_cm") @db.Decimal(8, 2)
  widthCm      Decimal? @map("width_cm") @db.Decimal(8, 2)
  heightCm     Decimal? @map("height_cm") @db.Decimal(8, 2)

  customsDeclarationValue Decimal? @map("customs_declaration_value") @db.Decimal(12, 2)
  customsCurrency         String?  @map("customs_currency") @db.VarChar(3)
  shippedAt   DateTime? @map("shipped_at")
  deliveredAt DateTime? @map("delivered_at")

  externalShipmentId String? @map("external_shipment_id")

  @@index([storeId, status])
  @@index([storeId, orderId])
  @@index([orderId])
  @@index([trackingNumber])
  @@map("shipments")
}

enum ShipmentStatus {
  PENDING
  LABEL_GENERATING
  LABEL_READY
  LABEL_FAILED
  SHIPPED
  IN_TRANSIT
  DELIVERED
  FAILED
  RETURNED
}

// Merchant-configured outbound webhook endpoints
model WebhookEndpoint {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  storeId String @map("store_id") @db.Uuid
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Restrict)

  url          String
  secret       String
  events       String[]
  isActive     Boolean @default(true) @map("is_active")

  failureCount     Int      @default(0) @map("failure_count")
  lastFailedAt     DateTime? @map("last_failed_at")
  lastSucceededAt  DateTime? @map("last_succeeded_at")
  disabledAt       DateTime? @map("disabled_at")
  disabledReason   String?   @map("disabled_reason")

  deliveries WebhookDelivery[]

  @@index([storeId, isActive])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  endpointId String @map("endpoint_id") @db.Uuid
  endpoint   WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Restrict)

  eventType    String @map("event_type")
  payload      Json
  status       WebhookDeliveryStatus @default(PENDING)

  httpStatus   Int?    @map("http_status")
  responseBody String? @map("response_body") @db.Text
  attemptCount Int     @default(0) @map("attempt_count")
  lastAttemptAt DateTime? @map("last_attempt_at")
  nextRetryAt   DateTime? @map("next_retry_at")
  completedAt   DateTime? @map("completed_at")
  errorMessage  String?   @map("error_message") @db.Text

  @@index([endpointId, status])
  @@index([status, nextRetryAt])
  @@index([createdAt])
  @@map("webhook_deliveries")
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCEEDED
  FAILED
  DEAD
}

// Deduplication for inbound Shopify webhooks
model ShopifyWebhookLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  shopifyWebhookId String   @unique @map("shopify_webhook_id")
  topic            String
  shopifyDomain    String   @map("shopify_domain")
  status           ShopifyWebhookStatus @default(RECEIVED)

  processedAt DateTime? @map("processed_at")
  errorMessage String?  @map("error_message") @db.Text

  @@index([shopifyDomain, topic])
  @@index([createdAt])
  @@map("shopify_webhook_logs")
}

enum ShopifyWebhookStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
}

// Idempotency keys scoped per store, expires after 24h
model IdempotencyKey {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  storeId String @map("store_id") @db.Uuid
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Restrict)

  key            String
  httpMethod     String @map("http_method")
  httpPath       String @map("http_path")
  requestHash    String @map("request_hash")

  responseStatus Int?    @map("response_status")
  responseBody   Json?   @map("response_body")

  lockedAt       DateTime? @map("locked_at")
  completedAt    DateTime? @map("completed_at")

  expiresAt DateTime @map("expires_at")

  @@unique([storeId, key], name: "uq_store_idempotency_key")
  @@index([expiresAt])
  @@map("idempotency_keys")
}

// Transactional outbox for at-least-once event delivery
model OutboxEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  storeId String @map("store_id") @db.Uuid
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Restrict)

  aggregateType String @map("aggregate_type")
  aggregateId   String @map("aggregate_id")
  eventType     String @map("event_type")
  payload       Json
  status        OutboxEventStatus @default(PENDING)
  publishedAt   DateTime?         @map("published_at")
  attempts      Int               @default(0)
  lastError     String?           @map("last_error") @db.Text
  nextRetryAt   DateTime?         @map("next_retry_at")

  @@index([status, createdAt])
  @@index([storeId, aggregateType, aggregateId])
  @@index([status, nextRetryAt])
  @@map("outbox_events")
}

enum OutboxEventStatus {
  PENDING
  PUBLISHED
  FAILED
}

// Saga orchestration with compensating transactions
model SagaInstance {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  type      SagaType
  status    SagaStatus @default(RUNNING)

  storeId   String @map("store_id") @db.Uuid
  idempotencyKey String @unique @map("idempotency_key")

  input     Json     @default("{}")
  output    Json?

  error     String?  @db.Text

  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  steps SagaStep[]

  @@index([storeId, type])
  @@index([status])
  @@index([type, status])
  @@index([storeId, idempotencyKey])
  @@map("saga_instances")
}

model SagaStep {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sagaId String       @map("saga_id") @db.Uuid
  saga   SagaInstance @relation(fields: [sagaId], references: [id], onDelete: Cascade)

  stepName  String @map("step_name")
  stepIndex Int    @map("step_index")

  status SagaStepStatus @default(PENDING)
  idempotencyKey String @unique @map("idempotency_key")

  input  Json?
  output Json?

  error    String? @db.Text
  attempts Int @default(0)

  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  @@index([sagaId, stepIndex])
  @@index([sagaId, status])
  @@map("saga_steps")
}

enum SagaType {
  ORDER_PROCESSING
  FULFILLMENT
}

enum SagaStatus {
  RUNNING
  COMPLETED
  COMPENSATING
  COMPENSATED
  FAILED
}

enum SagaStepStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  COMPENSATING
  COMPENSATED
  SKIPPED
}
